# Engram production env template -- consume via `op inject -i .env.template -o .env`.
# All op:// references resolve from your 1Password vault; the rendered .env
# MUST be chmod 600 and never committed.
#
# Source of truth: docker-compose.prod.yaml env block (kept in sync by hand).

# Image build version. Bump when publishing a new container.
ENGRAM_VERSION=0.3.0

# Engram daemon API key. Generated per deployment rotation.
ENGRAM_API_KEY={{ op://<your-vault>/engram-api-key/credential }}

# MiniMax fallback embedder credential. Used when Ollama nomic-embed-text is
# unreachable (network drop, model not loaded). Empty disables the fallback.
MINIMAX_API_KEY={{ op://<your-vault>/minimax-api-key/credential }}
